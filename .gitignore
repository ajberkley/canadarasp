# Artifacts the docker local stack writes into the bind-mounted source tree.
# locations.js / new-locations.js are also touched by production scp uploads,
# so they were already living as ad-hoc "regenerated" files in the repo —
# tracked but accepted as dirty after every cycle. Don't add them here.

# Local docker secrets (Google Maps API key, etc.)
docker/.env

# Lisp compilation caches under continental-test/
continental-test/*.cache

# Per-cycle windgram dispatch script (regenerated by every compute run)
continental-test/plot-generation/run-my-windgrams.sh

# Optional editor / OS noise
.DS_Store
*.swp
*~

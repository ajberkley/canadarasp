# Copy to docker/.env (which is .gitignored) and fill in.
#
# Google Maps JavaScript API key — see docker/README.md "Front-end caveats".
# Restrict it to HTTP referrer http://localhost:8080/* and
# http://127.0.0.1:8080/* in the Google Cloud console.
GMAPS_API_KEY=

# Linux only: set to your host user's UID/GID (output of `id -u` / `id -g`)
# so files the container writes back through the bind mount stay owned by
# you. macOS/OrbStack remaps automatically — leave these unset there.
HOST_UID=1000
HOST_GID=1000
